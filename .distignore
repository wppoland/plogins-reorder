# Files excluded from the wp.org build. Reorder is self-contained and has no
# runtime Composer dependencies, so /vendor (dev-only tooling) is excluded; the
# plugin ships with a PSR-4 fallback autoloader in autoload.php.
/vendor
/.git
/.github
/.gitignore
/.distignore
/.wp-env.json
/.wp-env.override.json
/node_modules
/tests
/scripts
/docs
/composer.json
/composer.lock
/package.json
/package-lock.json
/phpcs.xml.dist
/phpstan.neon.dist
/phpstan-baseline.neon
/playwright.config.ts
/tsconfig.json
/vite.config.ts
/README.md
/SPEC.md
/.DS_Store

.DS_Store
/.wordpress-org
/test-results
/playwright-report
/.playwright-mcp
